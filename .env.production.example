# Copy this to .env on the Ubuntu VPS and fill the secret values before running ./deploy.sh.

# Database container
DB_ROOT_PASSWORD=replace-with-a-long-random-root-password
DB_HOST=db
DB_PORT=3306
DB_NAME=blog_engine
DB_USERNAME=blog_app
DB_PASSWORD=replace-with-a-long-random-app-password

# Bootstrap platform admin (created on first startup if missing)
BLOG_ADMIN_EMAIL=admin@seinnlae.me
BLOG_ADMIN_USERNAME=admin
BLOG_ADMIN_PASSWORD=replace-with-a-long-random-admin-password

# SMTP for OTP emails
BLOG_MAIL_FROM=
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS=true

# Google OAuth2
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# App
BLOG_SITE_NAME=The Journal
BLOG_BASE_URL=https://seinnlae.me
BLOG_UPLOAD_DIR=/app/data/uploads
SPRING_THYMELEAF_CACHE=true
SERVER_FORWARD_HEADERS_STRATEGY=framework
SERVER_SERVLET_SESSION_COOKIE_SECURE=true
