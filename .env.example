# Copy to .env and fill in your values:
#   cp .env.example .env

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blog_engine
DB_USERNAME=root
DB_PASSWORD=

# Bootstrap platform admin (created on first startup if missing)
BLOG_ADMIN_EMAIL=admin@localhost
BLOG_ADMIN_USERNAME=admin
BLOG_ADMIN_PASSWORD=change-me-admin

# SMTP (leave BLOG_MAIL_FROM empty to log OTP codes to console in dev)
BLOG_MAIL_FROM=
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false

# Google OAuth2
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# App
BLOG_SITE_NAME=The Journal
BLOG_BASE_URL=http://localhost:8080
